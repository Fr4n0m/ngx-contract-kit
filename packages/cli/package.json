{
  "name": "@fr4n0m/contract-kit",
  "version": "1.0.0",
  "private": false,
  "description": "CLI and library for contract-driven API development between Angular and NestJS",
  "type": "commonjs",
  "main": "dist/bin.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.js"
    },
    "./diff": {
      "types": "./dist/diff.d.ts",
      "import": "./dist/diff.mjs",
      "require": "./dist/diff.js"
    },
    "./mock": {
      "types": "./dist/mock.d.ts",
      "import": "./dist/mock.mjs",
      "require": "./dist/mock.js"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "import": "./dist/zod.mjs",
      "require": "./dist/zod.js"
    },
    "./nestjs": {
      "types": "./dist/nestjs.d.ts",
      "import": "./dist/nestjs.mjs",
      "require": "./dist/nestjs.js"
    },
    "./generator-ts": {
      "types": "./dist/generator-ts.d.ts",
      "import": "./dist/generator-ts.mjs",
      "require": "./dist/generator-ts.js"
    },
    "./generator-angular": {
      "types": "./dist/generator-angular.d.ts",
      "import": "./dist/generator-angular.mjs",
      "require": "./dist/generator-angular.js"
    }
  },
  "bin": {
    "contract-kit": "dist/bin.js",
    "ngx-contract-kit": "dist/bin.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fr4n0m/contract-diff": "workspace:*",
    "@fr4n0m/core": "workspace:*",
    "@fr4n0m/generator-angular-client": "workspace:*",
    "@fr4n0m/generator-typescript": "workspace:*",
    "@fr4n0m/mock-generator": "workspace:*",
    "@fr4n0m/plugin-nestjs": "workspace:*",
    "@fr4n0m/validator-zod": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  },
  "license": "MIT",
  "homepage": "https://ngx-contract-kit-docs.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fr4n0m/ngx-contract-kit.git"
  },
  "bugs": {
    "url": "https://github.com/Fr4n0m/ngx-contract-kit/issues"
  },
  "author": "Fr4n0m (https://codebyfran.es)",
  "keywords": [
    "contract-kit",
    "angular",
    "nestjs",
    "backend",
    "api",
    "open-source",
    "cli"
  ]
}
