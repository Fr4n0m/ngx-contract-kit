{
  "name": "@ngx-contract-kit/generator-angular-client",
  "version": "0.1.0",
  "private": false,
  "description": "Angular client generator for ngx-contract-kit contracts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "echo generator-angular-client: no lint step yet"
  },
  "dependencies": {
    "@ngx-contract-kit/core": "workspace:*"
  }
}
