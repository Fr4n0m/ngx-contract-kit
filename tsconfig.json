{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "apps/docs/.vitepress/**/*.ts",
    "apps/docs/.vitepress/**/*.vue",
    "apps/docs/i18n/**/*.json",
    "packages/**/*.ts"
  ]
}
