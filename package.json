{
  "name": "ngx-contract-kit",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Angular + backend API contract toolkit.",
  "license": "MIT",
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "ckit:init": "node packages/cli/bin/ngx-contract-kit.js init",
    "ckit:generate": "node packages/cli/bin/ngx-contract-kit.js generate",
    "ckit:check": "node packages/cli/bin/ngx-contract-kit.js check",
    "docs:dev": "pnpm --filter @ngx-contract-kit/docs dev",
    "docs:build": "pnpm --filter @ngx-contract-kit/docs build"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  }
}
