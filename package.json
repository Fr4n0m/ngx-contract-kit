{
  "name": "ngx-contract-kit",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Angular + backend API contract toolkit.",
  "license": "MIT",
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "ckit:init": "tsx packages/cli/src/bin.ts init",
    "ckit:generate": "tsx packages/cli/src/bin.ts generate",
    "ckit:check": "tsx packages/cli/src/bin.ts check",
    "docs:dev": "pnpm --filter @ngx-contract-kit/docs dev",
    "docs:build": "pnpm --filter @ngx-contract-kit/docs build"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
