  "cards": [
    {
      "kicker": "PROBLEMA",
      "title": "Frontend y backend se desalinean",
      "copy": "Los equipos duplican DTOs, clientes y supuestos de endpoints en varias capas."
    },
    {
      "kicker": "SOLUCIÓN",
      "title": "Generación contract-first",
      "copy": "Define endpoints una sola vez y genera artefactos para mantener todo alineado."
    },
    {
      "kicker": "ESTADO",
      "title": "MVP ejecutable disponible",
      "copy": "La versión actual incluye flujo CLI de init, generate y check de compatibilidad."
    }
  ],
  "whatYouGet": {
    "title": "Qué Incluye",
    "items": [
      {
        "kicker": "CLI",
        "copy": "Comandos para inicializar proyectos, generar artefactos y detectar breaking changes."
      },
      {
        "kicker": "CORE",
        "copy": "Validación estricta del esquema y generación determinista del resumen de endpoints."
      },
      {
        "kicker": "ROADMAP",
        "copy": "Generador Angular y capa de plugins backend en desarrollo activo."
      }
    ]
  },
  "howItWorks": {
    "title": "Cómo Funciona",
    "intro": "Del contrato a una integración segura para release en cuatro pasos prácticos.",
    "steps": [
      {
        "title": "Define tu contrato",
        "detail": "Crea definiciones de endpoints en contracts/*.contract.json con shape de request y response.",
        "command": "pnpm ckit:init"
      },
      {
        "title": "Genera artefactos tipados",
        "detail": "Produce modelos y salidas deterministas a partir del contrato.",
        "command": "pnpm ckit:generate"
      },
      {
        "title": "Conecta Angular + backend",
        "detail": "Integra los outputs generados en clientes Angular y handlers backend para mantener ambos lados alineados."
      },
      {
        "title": "Valida compatibilidad antes de publicar",
        "detail": "Ejecuta checks de diff del contrato para detectar breaking changes en CI.",
        "command": "pnpm ckit:check"
      }
    ],
    "example": {
      "title": "Ejemplo mínimo de contrato",
      "fileLabel": "contracts/users.contract.json",
      "code": "{\n  \"service\": \"users\",\n  \"endpoints\": [{\n    \"path\": \"/users/:id\",\n    \"method\": \"GET\",\n    \"response\": { \"200\": { \"id\": \"string\", \"email\": \"string\" } }\n  }]\n}"
    },
    "releaseChecks": {
      "title": "Checklist de release",
      "items": [
        "El schema se mantiene válido y determinista.",
        "Los artefactos generados están sincronizados con el contrato.",
        "No hay breaking changes sin versionado intencional."
      ]
    },
    "commandsTitle": "Comandos base",
    "commands": ["pnpm ckit:init", "pnpm ckit:generate", "pnpm ckit:check"]
  },
